cat > .gitignore << 'EOF'
# Dependencies
node_modules/

# Build outputs
dist/
dist-client/
src/client/dist/
src/server/dist/

# Env
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Editor
.vscode/*
!.vscode/extensions.json
.idea/

# OS
.DS_Store
Thumbs.db

# TypeScript build info
*.tsbuildinfo
EOF
